# Ministack (emulador AWS local) — docs/01-dominio-e-contratos.md §8
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# DynamoDB
ORDERS_TABLE_NAME=orders
PROCESSED_MESSAGES_TABLE_NAME=processed_messages

# S3
PEDIDOS_BUCKET_NAME=pedidos-bucket

# SQS — uma variável por fila (docs/01-dominio-e-contratos.md §4)
SOLICITAR_PEDIDO_QUEUE_URL=http://localhost:4566/000000000000/solicitar_pedido_queue
EDITAR_PEDIDO_QUEUE_URL=http://localhost:4566/000000000000/editar_pedido_queue
CANCELAR_PEDIDO_QUEUE_URL=http://localhost:4566/000000000000/cancelar_pedido_queue
VALIDAR_PEDIDO_QUEUE_URL=http://localhost:4566/000000000000/validar_pedido_queue
VALIDAR_PEDIDO_RESPONSE_QUEUE_URL=http://localhost:4566/000000000000/validar_pedido_response_queue
PDF_REQUEST_QUEUE_URL=http://localhost:4566/000000000000/pdf_request_queue
PDF_RESPONSE_QUEUE_URL=http://localhost:4566/000000000000/pdf_response_queue
S3_NOTIFICATIONS_QUEUE_URL=http://localhost:4566/000000000000/s3_notifications_queue
PEDIDO_LINES_QUEUE_URL=http://localhost:4566/000000000000/pedido_lines_queue
